# direnv config — auto-loaded when entering this directory if direnv
# is installed. Without direnv, source manually: `source .envrc`.
#
# GUILD_ACTOR is the default --by / --from / --with for every gate /
# agora / devil verb. Override per-call with explicit flags. Set to
# `claude` because the develop branch is the dogfood branch — the
# Claude Code instance working here IS the actor.

export GUILD_ACTOR=claude
